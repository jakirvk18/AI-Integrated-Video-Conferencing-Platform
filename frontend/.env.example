# Only needed in production builds. In dev, Vite's proxy (vite.config.js)
# forwards /api and /ws to http://localhost:8000 automatically.

# Base URL of the FastAPI backend's HTTP API, e.g. https://api.yourapp.com
VITE_API_BASE_URL=https://api.yourapp.com

# Base URL for the signaling WebSocket, e.g. wss://api.yourapp.com
VITE_WS_BASE_URL=wss://api.yourapp.com
